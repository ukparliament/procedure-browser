			<!-- tbody -->
				<%#= render :partial => 'step/step_list_table_row', :collection => @steps %>
			<!-- /tbody -->
		<!-- /table -->
	<%# end -%>

	<%= render :partial => 'common/identifier', :object => @procedure %>
</div>	