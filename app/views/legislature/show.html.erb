<div class="reading-width">
	<% unless @legislature_houses.empty? -%>
		<div id="houses">
			<%= list_item_count_sentence( 'house', @legislature_houses.size ) %>
			<ol class="unnumbered link-list">
				<%= render :partial => 'house/house', :collection => @legislature_houses %>
			</ol>
		</div>
	<% end -%>

	<% unless @steps.empty? -%>
		<div id="steps">
			<%= list_item_count_sentence( 'step', @steps.size ) %>
			
			<%= render :partial => 'library_design/feeds/feeds' %>
		
			<%= content_tag( 'p', 'Steps listed are limited to those steps appearing in the work packages described or with the potential to appear in those work packages.' ) %>
		
			<table class="table">
				<%= render :partial => 'step/step_list_table_head' %>
				<tbody>
					<%= render :partial => 'step/step_list_table_row', :collection => @steps %>
				</tbody>
			</table>
		</div>
	<% end -%>

	<%= render :partial => 'common/identifier', :object => @legislature %>
</div>